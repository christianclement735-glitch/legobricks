    /* ── CONTRACT ── */
    .contract-bar {
      background: rgba(255,215,0,0.08);
      border: 2px solid rgba(255,215,0,0.35);
      border-radius: 12px;
      padding: 20px 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 32px;
