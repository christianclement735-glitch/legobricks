      border: none;
      padding: 8px 18px;
      border-radius: 6px;
      font-family: 'Nunito', sans-serif;
      font-weight: 800;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.15s;
      white-space: nowrap;
    }
    .copy-btn:hover { background: #e6c000; transform: translateY(-1px); }
    .copy-btn.copied { background: #22c55e; color: white; }

    /* ── SCROLL FX ── */
    .fade-in {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (max-width: 600px) {
      nav { padding: 12px 20px; }
      .nav-logo { font-size: 1.2rem; }
      .nav-links a { padding: 6px 12px; font-size: 0.8rem; }
      section { padding: 60px 16px; }
      .token-section { padding: 32px 20px; }
    }
  </style>
