    :root {
      --yellow: #FFD700;
      --red: #E3000B;
      --blue: #006CB7;
      --dark: #1a1a2e;
      --darker: #0f0f1a;
      --white: #FFFFFF;
      --light-gray: #f0f0f0;
      --brick-shadow: 4px 4px 0px rgba(0,0,0,0.35);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--darker);
      color: var(--white);
      overflow-x: hidden;
    }

    /* ── BRICK PATTERN BG ── */
    .brick-bg {
      background-color: var(--darker);
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,215,0,0.04) 39px, rgba(255,215,0,0.04) 40px),
        repeating-linear-gradient(90deg, transparent, transparent 79px, rgba(255,215,0,0.04) 79px, rgba(255,215,0,0.04) 80px);
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; width: 100%; z-index: 100;
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px 40px;
      background: rgba(15,15,26,0.92);
      backdrop-filter: blur(10px);
      border-bottom: 3px solid var(--yellow);
    }

    .nav-logo {
      font-family: 'Nunito', sans-serif;
      font-weight: 900;
      font-size: 1.6rem;
      color: var(--yellow);
      letter-spacing: -1px;
      text-shadow: 2px 2px 0px var(--red);
    }

    .nav-logo span { color: var(--white); }

    .nav-links { display: flex; gap: 12px; align-items: center; }

    .nav-links a {
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      padding: 8px 18px;
      border-radius: 6px;
      transition: all 0.2s;
    }

    .nav-twitter {
      background: var(--dark);
      color: var(--white);
      border: 2px solid #1d9bf0;
    }
    .nav-twitter:hover { background: #1d9bf0; }

    .nav-telegram {
      background: var(--blue);
      color: var(--white);
      border: 2px solid var(--blue);
    }
    .nav-telegram:hover { background: #0056a3; }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding: 120px 20px 60px;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at center, rgba(255,215,0,0.12) 0%, transparent 70%);
      pointer-events: none;
    }

    .brick-icon {
      font-size: 5rem;
      margin-bottom: 16px;
      display: block;
      animation: bounce 2s ease-in-out infinite;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-12px); }
    }

    .hero h1 {
      font-family: 'Nunito', sans-serif;
      font-weight: 900;
      font-size: clamp(3rem, 10vw, 7rem);
      line-height: 1;
      color: var(--yellow);
      text-shadow: 5px 5px 0px var(--red), 8px 8px 0px rgba(0,0,0,0.4);
      letter-spacing: -2px;
    }

    .hero-sub {
      font-size: clamp(1rem, 3vw, 1.4rem);
      color: rgba(255,255,255,0.75);
      margin: 16px auto;
      max-width: 560px;
      line-height: 1.6;
    }

    .hero-sub strong { color: var(--yellow); }

    .badge {
      display: inline-block;
      background: var(--blue);
      color: var(--white);
      font-weight: 700;
      font-size: 0.8rem;
      padding: 5px 14px;
      border-radius: 999px;
      margin-bottom: 20px;
      text-transform: uppercase;
      letter-spacing: 1px;
      border: 2px solid rgba(255,255,255,0.2);
    }

    .hero-buttons {
      display: flex; gap: 14px; flex-wrap: wrap;
      justify-content: center; margin-top: 32px;
    }

    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 14px 28px;
      border-radius: 8px;
      font-family: 'Nunito', sans-serif;
      font-weight: 800;
      font-size: 1rem;
      text-decoration: none;
      transition: all 0.15s;
      border: none; cursor: pointer;
    }

    .btn-primary {
      background: var(--yellow);
      color: var(--darker);
      box-shadow: var(--brick-shadow);
    }
    .btn-primary:hover { transform: translate(-2px,-2px); box-shadow: 6px 6px 0px rgba(0,0,0,0.4); }

    .btn-twitter {
      background: transparent;
      color: var(--white);
      border: 2px solid #1d9bf0;
    }
    .btn-twitter:hover { background: #1d9bf0; }

    .btn-telegram {
      background: transparent;
      color: var(--white);
      border: 2px solid var(--blue);
    }
    .btn-telegram:hover { background: var(--blue); }

    /* ── TICKER ── */
    .ticker {
      background: var(--red);
      padding: 12px 0;
      overflow: hidden;
      border-top: 3px solid var(--yellow);
      border-bottom: 3px solid var(--yellow);
    }

    .ticker-inner {
      display: flex;
      gap: 60px;
      animation: scroll 20s linear infinite;
      white-space: nowrap;
      width: max-content;
    }

    @keyframes scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .ticker span {
      font-family: 'Nunito', sans-serif;
      font-weight: 900;
      font-size: 0.95rem;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    /* ── SECTIONS ── */
    section {
      padding: 80px 20px;
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-label {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: var(--yellow);
      margin-bottom: 12px;
    }

    h2 {
      font-family: 'Nunito', sans-serif;
      font-weight: 900;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      line-height: 1.1;
      margin-bottom: 16px;
    }

    /* ── ABOUT ── */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }

    @media (max-width: 700px) { .about-grid { grid-template-columns: 1fr; } }

    .about-text p {
      color: rgba(255,255,255,0.7);
      line-height: 1.8;
      font-size: 1.05rem;
      margin-bottom: 16px;
    }

    .brick-stack {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .brick {
      background: var(--yellow);
      color: var(--darker);
      font-family: 'Nunito', sans-serif;
      font-weight: 900;
      font-size: 0.85rem;
      padding: 18px 10px;
      text-align: center;
      border-radius: 8px;
      box-shadow: 0 5px 0 #b8960a;
      transition: transform 0.2s;
    }

    .brick:nth-child(2) { background: var(--red); color: var(--white); box-shadow: 0 5px 0 #8a0007; }
    .brick:nth-child(3) { background: var(--blue); color: var(--white); box-shadow: 0 5px 0 #003f70; }
    .brick:nth-child(4) { background: var(--blue); color: var(--white); box-shadow: 0 5px 0 #003f70; }
    .brick:nth-child(5) { background: var(--yellow); color: var(--darker); box-shadow: 0 5px 0 #b8960a; }
    .brick:nth-child(6) { background: var(--red); color: var(--white); box-shadow: 0 5px 0 #8a0007; }

    .brick:hover { transform: translateY(-4px); }

    .brick .icon { font-size: 1.6rem; display: block; margin-bottom: 6px; }

